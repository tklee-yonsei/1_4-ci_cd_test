{
    "name": "Python Telecom Research",
    "build": {
      "dockerfile": "Dockerfile",
      "context": ".."
    },
    "customizations": {
      "vscode": {
        "extensions": [
          "ms-python.python",
          "ms-python.black-formatter",
          "ms-toolsai.jupyter"
        ],
        "settings": {
          "python.defaultInterpreterPath": "/usr/local/bin/python",
          "editor.formatOnSave": true,
          "[python]": {
            "editor.defaultFormatter": "ms-python.black-formatter"
          }
        }
      }
    }
  }